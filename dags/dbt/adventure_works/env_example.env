# Desenvolvimento local: use o .env na raiz do projeto Astro (recomendado).
# Este arquivo é apenas referência das variáveis usadas em profiles.yml.

GCP_DEV_PROJECT=seu-projeto-gcp
DBT_DEV_SCHEMA=seu_schema_dev  # apenas letras, números e underscores (sem hífens)
GCP_DEV_KEYFILE_PATH=/usr/local/airflow/.credentials/gcp-dev-key.json

GCP_PROD_PROJECT=seu-projeto-gcp
DBT_PROD_SCHEMA=seu_schema_prod
GCP_PROD_KEYFILE_PATH=/usr/local/airflow/.credentials/gcp-prod-key.json

# Target do dbt usado pelo Cosmos/Airflow: dev ou prod
DBT_TARGET=prod
